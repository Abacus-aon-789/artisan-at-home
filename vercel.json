{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/private-chef", "destination": "/services/private-chef/", "permanent": true },
    { "source": "/event-catering", "destination": "/services/event-catering/", "permanent": true },
    { "source": "/corporate-catering", "destination": "/services/corporate-catering/", "permanent": true },
    { "source": "/services/services-private-chef", "destination": "/services/private-chef/", "permanent": true },
    { "source": "/kitchen-hero", "destination": "/contact-us/", "permanent": false },
    { "source": "/home-page", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    }
  ]
}
